# Required: portal registration endpoint
PORTAL_REGISTRATION_URL=https://onlyoffice.io/apisystem/portal

# Required: owner credentials
DOCSPACE_OWNER_EMAIL=your-email@example.com
DOCSPACE_OWNER_PASSWORD=your-password

# Required for tests covering paid features
MACHINEKEY=
PKEY=

# Local build: set to your local DocSpace domain
# When set, tests run against local instance
LOCAL_PORTAL_DOMAIN=

# Nextcloud credentials for backup-to-third-party tests
NEXTCLOUD_URL=
NEXTCLOUD_LOGIN=
NEXTCLOUD_PASSWORD=

# AWS S3 credentials for backup-to-custom-cloud tests
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
S3_REGION=

# AI provider API keys (for AI agents tests)
DEEPSEEK_API_KEY=
XAI_API_KEY=
GOOGLE_AI_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TOGETHER_AI_API_KEY=
EXA_API_KEY=